import java.util.Scanner;

public class CashRecords {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      int numElements;
		int i;

		numElements = scnr.nextInt();

      int[] truckIds = new int[numElements];
      int[] serviceCosts = new int [numElements];
      
      for (i = 0; i < numElements; ++i) {
         truckIds[i] = scnr.nextInt();
         serviceCosts[i] = scnr.nextInt();
      }

      for (i = 0; i < truckIds.length; ++i) {
			System.out.println("Truck id: " + truckIds[i] + ", Costs: $" + serviceCosts[i]);
		}
   }
}

// Integer numElements is read from input, representing the number of pairs of integers remaining in the input. Declare two integer arrays, truckIds and serviceCosts, of numElements elements each. Then, read numElements pairs of integers from input. For each pair read, store the first integer into truckIds and the second integer into serviceCosts.