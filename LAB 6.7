import java.util.Scanner;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.PrintWriter;
import java.io.IOException;

public class LabProgram {
   public static void main(String[] args) throws IOException {
      Scanner scnr = new Scanner(System.in);
      
      /* TODO: Declare any necessary variables here.*/
      FileInputStream inStream = null;
      FileOutputStream outStream = null;
      PrintWriter outWriter = null;
      Scanner inFile = null;

      String student, firstName, lastName, fileName;
      Character letterGrade = 'x';
      int i, count = 0, midterm1Score, midterm2Score, finalScore, averageScore;
      double midterm1Average = 0.0, midterm2Average = 0.0, finalScoreAverage = 0.0;
	  
      // TODO: Read a file name from the user and read the tsv file here. 
      System.out.print("Enter filename: ");
      fileName = scnr.nextLine();
      inStream = new FileInputStream(fileName);
      inFile = new Scanner(inStream);

      outStream = new FileOutputStream("report.txt");
      outWriter = new PrintWriter(outStream);

      while (inFile.hasNext()) {
         // Read Variables
         firstName = inFile.next();
         lastName = inFile.next();
         midterm1Score = inFile.nextInt();
         midterm2Score = inFile.nextInt();
         finalScore = inFile.nextInt();
         count = count + 1;

         // Calculate Average Score
         averageScore = ((midterm1Score + midterm2Score + finalScore) / 3);

         // Find Letter Grade with averageScore
         if (averageScore >= 90) {
            letterGrade = 'A';
         }
         else if ((averageScore < 90) && (averageScore >= 80)) {
            letterGrade = 'B';
         }
         else if ((averageScore < 80) && (averageScore >= 70)) {
            letterGrade = 'C';
         }
         else if ((averageScore < 70) && (averageScore >= 60)) {
            letterGrade = 'D';
         }
         else if (averageScore < 60) {
            letterGrade = 'F';
         }
         
         // Find Midterm 1 Average
         midterm1Average += midterm1Score;

         // Find Midterm 2 Average
         midterm2Average += midterm2Score;

         // Find Final Score Average
         finalScoreAverage += finalScore;

         outWriter.printf("%s\t%s\t%d\t%d\t%d\t%s\n", firstName, lastName, midterm1Score, midterm2Score, finalScore, letterGrade);
         outWriter.flush();
      } 
      // Print Averages
      outWriter.printf("\n%s %.2f%s %.2f%s %.2f\n", "Averages: Midterm1", (midterm1Average / count), ", Midterm2", (midterm2Average / count), ", Final", (finalScoreAverage / count));

      // Close Files
      outWriter.close();
      inFile.close();
   }
}

