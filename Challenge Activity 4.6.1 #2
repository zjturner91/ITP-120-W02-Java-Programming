import java.util.Scanner;

public class ValidInvalid {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      String password;
      int i;
      int count;
      
      password = scnr.next();
      count = 0;

      for (i = 0; i < (password.length() - 1); ++i) {
         if (Character.isLetter(password.charAt(i))) {
            count = count + 1;
         }
      }
      if ((count < 6) && (password.length() <= 7)) {
         System.out.println("Valid");
      }
      else {
         System.out.println("Invalid");
      }
   }
}

// String password is read from input. For each character in password that is a letter, increment count by 1. Then, output "Valid" if count contains no more than 5 letters and password's length is less than or equal to 7. Otherwise, output "Invalid". End each output with a newline.