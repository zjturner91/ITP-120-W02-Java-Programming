import java.util.Scanner;
import java.io.PrintWriter;
import java.io.FileOutputStream;
import java.io.IOException;

public class PearFileOutput {
   public static void main(String[] args) throws IOException {
      Scanner scnr = new Scanner(System.in);
      String nameOfFile;
      String pearPurchase;
      
      FileOutputStream pearFStream = null;
      PrintWriter pearOut = null;
      
      nameOfFile = scnr.next();
      pearFStream = new FileOutputStream(nameOfFile);
      pearOut = new PrintWriter(pearFStream);

      pearPurchase = scnr.next();

      pearOut.println(pearPurchase + " bought some pears");
      pearOut.close();
   }
}

