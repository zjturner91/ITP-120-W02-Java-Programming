import java.util.Scanner;

public class ForLoops {
   public static void main (String [] args) {
      int userNum;
      int i;
      
      Scanner input = new Scanner(System.in);
      userNum = input.nextInt();
      
      for (i = 1; i <= userNum; i++) {
         System.out.print(i + " ");
      }
   }
}

// Write a for loop that prints: 1 2 … userNum
