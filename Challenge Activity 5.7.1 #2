import java.util.Scanner;

public class ArrayModification {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      int[] valsArray;
      int numValues;
      int i;

      numValues = scnr.nextInt();

      valsArray = new int[numValues];

      valsArray[0] = scnr.nextInt();
      valsArray[1] = scnr.nextInt();
      
      for (i = 2; i < valsArray.length; ++i) {
         valsArray[i] = valsArray[i - 1] + valsArray[i - 2];
      }

      System.out.print("Sequence: ");
      for (i = 0; i < valsArray.length; ++i) {
         System.out.print(valsArray[i] + " ");
      }
      System.out.println();
   }
}

