import java.util.Scanner;
import java.io.FileInputStream;
import java.io.IOException;

public class FileReading {
   public static void main(String[] args) throws IOException {
      Scanner scnr = new Scanner(System.in);
      FileInputStream fileByteStream = null;
      Scanner inFS = null;
      String fileName;
      int dresserQuantity;
		int totalDresserQuantity;

      fileName = scnr.next();

      fileByteStream = new FileInputStream(fileName);
      inFS = new Scanner(fileByteStream);
		totalDresserQuantity = 0;
		System.out.println("Started with: " + totalDresserQuantity);

      while (inFS.hasNextInt()) {
         dresserQuantity = inFS.nextInt();

         System.out.println(dresserQuantity);
			totalDresserQuantity = totalDresserQuantity + dresserQuantity;
      }

      if (inFS.hasNext()) {
         System.out.println("Reading stopped at " + inFS.next());
      }
      else {
         System.out.println("Reached end of file");
      }

		System.out.println("Sum: " + totalDresserQuantity);

      fileByteStream.close();
   }
}

