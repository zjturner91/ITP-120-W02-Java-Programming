import java.util.Scanner;

public class CombineArrays {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      final int NUM_VALS = 4;
      int[] busRegistrations = new int[NUM_VALS];
      int[] distanceTraveled = new int[NUM_VALS];
      int i; 

      for (i = 0; i < busRegistrations.length; ++i) {
         busRegistrations[i] = scnr.nextInt();
      }

      for (i = 0; i < distanceTraveled.length; ++i) {
         distanceTraveled[i] = scnr.nextInt();
      }

      for (i = 0; i < distanceTraveled.length; ++i) {
         if (distanceTraveled[i] % 2 == 0) {
            System.out.print(busRegistrations[i] + " ");
         }
      }
      System.out.println();
   }
}

// Integer arrays busRegistrations and distanceTraveled are read from input. For each element in distanceTraveled, if an element is an even integer, output busRegistrations' corresponding element followed by a space. After the final output, end with a newline.
// Ex: If the input is:
// 137 158 111 146
// 50 23 31 36
// then the output is:
// 137 146 