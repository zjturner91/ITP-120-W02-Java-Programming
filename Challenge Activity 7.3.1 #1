import java.util.Scanner;
import java.io.FileInputStream;
import java.io.IOException;

public class ReadInputFile {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      String weightFileName;
      double weightVal;

      weightFileName = scnr.next();

      try (Scanner weightFileScanner = new Scanner(new FileInputStream(weightFileName))) {
         weightVal = weightFileScanner.nextDouble();
         System.out.println("Value read from " + weightFileName + ": " + weightVal);
      }
      catch (IOException e) {
         System.out.println(weightFileName + ": Open operation failed");
      }
   }
}

// String weightFileName is read from input. The try block opens a file named weightFileName to read a floating-point number into weightVal.
