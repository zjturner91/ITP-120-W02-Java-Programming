import java.util.Scanner;
import java.io.FileInputStream;
import java.io.IOException;

public class MelonDataReader {
   public static void main(String[] args) throws IOException {
      Scanner scnr = new Scanner(System.in);
      String dataFileName;
      double melonWeight;
      FileInputStream fStream = null;
      Scanner dataFS = null;

      dataFileName = scnr.next();

      fStream = new FileInputStream(dataFileName);
      dataFS = new Scanner(fStream);

      melonWeight = dataFS.nextDouble();
      System.out.println(melonWeight);
      fStream.close();

      // Attempt to access the file for testing purpose
      fStream.read();
   }
}

