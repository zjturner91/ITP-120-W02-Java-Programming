import java.util.Scanner;

public class MileRange {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      final int ARR_LENGTH = 10;
      int[] dailyMiles = new int[ARR_LENGTH];
      int i;

      for (i = dailyMiles.length - 1; i >= (ARR_LENGTH / 2); --i) {
         dailyMiles[i] = scnr.nextInt();
      }

      for (i = 0; i < dailyMiles.length; ++i) {
         System.out.print(dailyMiles[i] + " ");
      }

      System.out.println();
   }
}

